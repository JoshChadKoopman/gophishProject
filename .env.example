# Nivoxis CyberAwareness Platform — Environment Variables
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Keycloak admin credentials (used on first boot to create the admin account)
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password

# ---------------------------------------------------------------------------
# Keycloak database credentials
# ---------------------------------------------------------------------------
KEYCLOAK_DB_PASSWORD=change-me-db-password

# ---------------------------------------------------------------------------
# OIDC client configuration
# These values must match what you configure in the Keycloak admin UI:
#   Realm:       nivoxis
#   Client ID:   gophish
#   Access type: confidential
#   Redirect URI: value of OIDC_REDIRECT_URL below
# ---------------------------------------------------------------------------
KEYCLOAK_CLIENT_ID=gophish
KEYCLOAK_CLIENT_SECRET=paste-client-secret-from-keycloak-here
OIDC_REDIRECT_URL=https://your-domain.example.com/auth/oidc/callback

# ---------------------------------------------------------------------------
# MFA TOTP encryption key
# Generate with: openssl rand -base64 32
# Must be exactly 32 bytes when base64-decoded.
# ---------------------------------------------------------------------------
MFA_TOTP_ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32

# ---------------------------------------------------------------------------
# Keycloak realm setup (one-time, via Keycloak Admin UI at http://localhost:8888)
# 1. Create realm:  nivoxis
# 2. Create client: gophish  (confidential, standard flow, set redirect URI above)
# 3. Add realm roles: superadmin, org_admin, campaign_manager, trainer, auditor, learner
# 4. Enable OTP policy for groups: superadmin, org_admin
# 5. Assign the KEYCLOAK_CLIENT_SECRET above from the client Credentials tab
# ---------------------------------------------------------------------------
