# Keycloak OIDC client credentials
KEYCLOAK_CLIENT_ID=gophish
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_generate_a_random_secret

# OIDC redirect URL (adjust host/port for production)
OIDC_REDIRECT_URL=https://localhost:3333/auth/oidc/callback

# MFA TOTP encryption key (32 bytes, base64-encoded)
# Generate with: openssl rand -base64 32
MFA_TOTP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# Keycloak admin credentials
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_set_a_strong_password

# Keycloak PostgreSQL database password
KEYCLOAK_DB_PASSWORD=CHANGE_ME_set_a_strong_password
